---
import "../styles/global.css";

export interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Gymple - Sistema de Gestión Inteligente para Gimnasios",
  description = "Automatiza la cobranza, gestiona socios y envía recordatorios por WhatsApp. El software todo en uno para modernizar tu gimnasio.",
} = Astro.props;
---

<!doctype html>
<html lang="es" class="antialiased">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="generator" content="Astro" />

    <link rel="canonical" href={Astro.site ? new URL(Astro.url.pathname, Astro.site).toString() : Astro.url.pathname} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Instrument+Serif:wght@400&display=swap"
    />
  </head>
  <body class="font-sans antialiased">
    <slot />
  </body>
</html>

