---
const points = [
  {
    title: "Multi-tenant aislado",
    description:
      "Cada gimnasio tiene su propio entorno con URL personalizada. Tus datos nunca se mezclan con otro negocio.",
    iconPath: "M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z",
  },
  {
    title: "Filtrado inteligente por período",
    description:
      "Filtrá reportes por día, semana, mes o rango personalizado para tomar decisiones con datos reales.",
    iconPath: "M22 3H2l8 9.46V19l4 2v-8.54L22 3z",
  },
  {
    title: "Backups y encriptación automática",
    description:
      "Respaldos diarios automáticos y encriptación de datos sensibles.",
    iconPath:
      "M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4",
  },
  {
    title: "Acceso desde cualquier dispositivo",
    description:
      "Accedé desde computadora, tablet o celular sin instalar nada.",
    iconPath:
      "M12 18h.01 M7 21h10a2 2 0 0 0 2-2V5a2 2 0 0 0-2-2H7a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2z",
  },
];

const slides = [
  { src: "/carrusel.webp", alt: "Vista plataforma 1" },
  { src: "/carrusel2.webp", alt: "Vista plataforma 2" },
  { src: "/carrusel3.webp", alt: "Vista plataforma 3" },
  { src: "/carrusel4.webp", alt: "Vista plataforma 4" },
  { src: "/carrusel5.webp", alt: "Vista plataforma 5" },
];
---

<section
  class="w-full py-16 md:py-24 border-b border-[rgba(26,47,29,0.12)] flex justify-center bg-[#FDFCFB]"
>
  <div
    class="w-full max-w-[1200px] px-6 md:px-12 grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-center"
  >
    <!-- TEXTO -->
    <div class="flex flex-col gap-8">
      <div class="flex flex-col gap-4">
        <span class="text-xs font-bold uppercase text-[#1A2F1D]"
          >Tecnología</span
        >

        <h2 class="text-[#49423D] text-3xl md:text-5xl font-bold leading-tight">
          Gestión moderna <span class="text-[#38523C]">segura y 100% nube</span>
        </h2>

        <p class="text-[#38523C] opacity-80 max-w-[480px]">
          Infraestructura de alto rendimiento para que tu gimnasio nunca se
          detenga.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {
          points.map((point) => (
            <article class="p-5 bg-white border border-[#E0DEDB] rounded-2xl flex flex-col gap-3">
              <div class="w-10 h-10 bg-[#F7F5F3] rounded-xl flex items-center justify-center">
                <svg
                  width="20"
                  height="20"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path d={point.iconPath} />
                </svg>
              </div>

              <div>
                <h3 class="text-sm font-bold text-[#49423D]">{point.title}</h3>

                <p class="text-xs text-[#38523C] opacity-90">
                  {point.description}
                </p>
              </div>
            </article>
          ))
        }
      </div>
    </div>

    <!-- CARRUSEL -->
    <div class="relative">
      <div
        class="relative rounded-2xl bg-white border border-[#E0DEDB] shadow-2xl overflow-hidden"
      >
        <div
          class="h-8 bg-[#F7F5F3] border-b border-[#E0DEDB] flex items-center px-4 gap-2"
        >
          <div class="w-2.5 h-2.5 rounded-full bg-[#ff5f56]"></div>
          <div class="w-2.5 h-2.5 rounded-full bg-[#ffbd2e]"></div>
          <div class="w-2.5 h-2.5 rounded-full bg-[#27c93f]"></div>
        </div>

        <div
          id="tech-carousel"
          class="flex overflow-x-scroll snap-x snap-mandatory"
          style="height:420px;"
        >
          {
            slides.map((slide, i) => (
              <div class="snap-start flex-shrink-0" style="flex:0 0 100%;">
                <img
                  src={slide.src}
                  alt={slide.alt}
                  loading={i === 0 ? "eager" : "lazy"}
                  class="w-full h-full object-cover"
                />
              </div>
            ))
          }
        </div>

        <div
          id="carousel-indicators"
          class="absolute bottom-4 left-1/2 -translate-x-1/2 flex gap-2 px-4 py-2 bg-black/10 backdrop-blur rounded-full"
        >
          {
            slides.map((_, i) => (
              <button
                class={`w-2.5 h-2.5 rounded-full bg-[#1A2F1D] ${i !== 0 ? "opacity-30" : ""}`}
              />
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  #tech-carousel {
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
  }

  #tech-carousel > div {
    scroll-snap-align: start;
    scroll-snap-stop: always;
  }

  #tech-carousel::-webkit-scrollbar {
    display: none;
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    const carousel = document.getElementById("tech-carousel");
    const dots = document.querySelectorAll("#carousel-indicators button");

    let index = 0;
    let paused = false;

    const slideWidth = () => carousel.clientWidth;

    function updateDots() {
      index = Math.round(carousel.scrollLeft / slideWidth());

      dots.forEach((dot, i) => {
        dot.style.opacity = i === index ? "1" : "0.3";
        dot.style.transform = i === index ? "scale(1.2)" : "scale(1)";
      });
    }

    carousel.addEventListener("scroll", updateDots, { passive: true });

    dots.forEach((dot, i) => {
      dot.addEventListener("click", () => {
        paused = true;

        carousel.scrollTo({
          left: i * slideWidth(),
          behavior: "smooth",
        });

        setTimeout(() => (paused = false), 3000);
      });
    });

    setInterval(() => {
      if (paused) return;

      index++;

      if (index >= carousel.children.length) {
        index = 0;
      }

      carousel.scrollTo({
        left: index * slideWidth(),
        behavior: "smooth",
      });
    }, 4000);
  });
</script>
