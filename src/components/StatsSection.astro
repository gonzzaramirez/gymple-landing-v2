---
const stats = [
  { value: "+85%", label: "Tasa de cobranza" },
  { value: "10h", label: "Ahorradas por semana" },
  { value: "-40%", label: "Menos morosidad" },
  { value: "24/7", label: "Acceso en la nube" },
];
---

<section
  class="w-full py-12 sm:py-16 md:py-20 border-b border-[rgba(26,47,29,0.12)] flex flex-col justify-center items-center"
  aria-labelledby="results-heading"
>
  <div class="w-full max-w-[700px] px-4 sm:px-6 mb-8 sm:mb-12 flex flex-col justify-start items-center gap-3 sm:gap-4">
    <h2
      id="results-heading"
      class="w-full text-center flex justify-center flex-col text-[#49423D] text-3xl md:text-4xl font-semibold leading-[1.1] md:leading-tight font-sans tracking-tight"
    >
      Resultados reales de gimnasios usando Gymple
    </h2>
  </div>

  <div class="w-full max-w-[900px] px-4 sm:px-8 grid grid-cols-2 md:grid-cols-4 gap-6 sm:gap-8">
    {stats.map((stat) => (
      <div class="flex flex-col items-center text-center">
        <span class="text-3xl sm:text-4xl md:text-5xl font-semibold text-[#1A2F1D] font-serif">{stat.value}</span>
        <span class="text-sm text-[#38523C] mt-2">{stat.label}</span>
      </div>
    ))}
  </div>
</section>
