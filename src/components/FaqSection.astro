---
import { faqData } from "../data/faq";
---

<section
  id="faq"
  class="w-full flex justify-center items-start"
  aria-labelledby="faq-heading"
>
  <div class="w-full max-w-[1000px] px-4 md:px-8 py-12 md:py-16 flex flex-col lg:flex-row justify-start items-start gap-6 lg:gap-12">
    <div class="w-full lg:flex-1 flex flex-col justify-center items-start gap-3 lg:py-5">
      <h2
        id="faq-heading"
        class="w-full flex flex-col justify-center text-[#49423D] font-semibold leading-tight md:leading-[44px] font-sans text-3xl md:text-4xl tracking-tight"
      >
        Preguntas Frecuentes
      </h2>
      <p class="w-full text-[#38523C] text-base font-normal leading-7 font-sans">
        Todo lo que necesitás saber<br class="hidden md:block" /> sobre Gymple.
      </p>
    </div>

    <div class="w-full lg:flex-[1.5] flex flex-col justify-center items-center">
      <div class="w-full flex flex-col">
        {faqData.map((item) => (
          <details class="w-full border-b border-[rgba(73,66,61,0.16)] group">
            <summary class="w-full px-4 py-4 flex justify-between items-center gap-5 text-left hover:bg-[rgba(73,66,61,0.02)] transition-colors duration-200 cursor-pointer list-none [&::-webkit-details-marker]:hidden">
              <span class="flex-1 text-[#49423D] text-base font-medium leading-6 font-sans">
                {item.question}
              </span>
              <span class="flex justify-center items-center">
                <svg
                  class="w-5 h-5 text-[rgba(73,66,61,0.60)] transition-transform duration-300 ease-in-out group-open:rotate-180"
                  width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"
                >
                  <path d="m6 9 6 6 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </span>
            </summary>
            <div class="px-4 pb-4 text-[#38523C] text-sm font-normal leading-6 font-sans">
              {item.answer}
            </div>
          </details>
        ))}
      </div>
    </div>
  </div>
</section>
