---
const features = [
  {
    title: "Gestión y control de socios en tiempo real",
    description:
      "Fichas de clientes completas, datos personales, historial de pagos y estados de cuota actualizados al instante.",
    iconPath:
      "M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2 M9 7a4 4 0 1 0 0-8 4 4 0 0 0 0 8z M22 21v-2a4 4 0 0 0-3-3.87 M16 3.13a4 4 0 0 1 0 7.75",
  },
  {
    title: "Control de membresías y vencimientos automáticos",
    description:
      "Definí planes mensuales, trimestrales o anuales. El sistema alerta vencimientos y bloquea accesos automáticamente.",
    iconPath:
      "M2 10h20 M22 6v12a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2z",
  },
  {
    title: "Registro de asistencia y control de accesos",
    description:
      "Control de asistencias mediante DNI. Solo ingresan socios con la cuota al día.",
    iconPath:
      "M13 4h3a2 2 0 0 1 2 2v14 M2 20h10 M10 20v-6a2 2 0 0 1 2-2h6 M2 14h2 M2 10h2 M2 6h2 M18 20a2 2 0 1 0 0-4 2 2 0 0 0 0 4z",
  },
  {
    title: "Recordatorios automáticos por WhatsApp",
    description:
      "Recordatorios de vencimiento enviados 3 días antes y el mismo día.",
    iconPath:
      "M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z",
  },
  {
    title: "Control de gastos e ingresos de tu gimnasio",
    description:
      "Registrá cobros y egresos diarios. Visualizá el balance mensual y por método de pago en un solo lugar.",
    iconPath: "M12 2v20 M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6",
  },
  {
    title: "Estadísticas y reportes con filtrado por tiempo",
    description:
      "Dashboards con métricas clave: socios activos, tasa de cobranza, ingresos. Filtrá por día, semana, mes o rango personalizado.",
    iconPath: "M3 3v18h18 M18 17V9 M13 17V5 M8 17v-3",
  },
  {
    title: "Gestión de rutinas y ejercicios digitales",
    description:
      "Los entrenadores crean rutinas personalizadas y los socios las ven desde su celular. Sin papeles ni pizarras.",
    iconPath:
      "M6.5 6.5h11 M6.5 17.5h11 M2 12h2 M20 12h2 M7 12h10 M4 7v10 M20 7v10",
  },
  {
    title: "Soporte dedicado y tecnología en la nube",
    description:
      "Accedé desde cualquier dispositivo, 24/7. Entorno aislado por gimnasio, backups automáticos y soporte por WhatsApp.",
    iconPath:
      "M17.5 19H9a7 7 0 1 1 6.71-9h1.79a4.5 4.5 0 1 1 0 9Z",
  },
];
---

<section class="w-full flex justify-center px-4 py-8">

  <!-- CONTENEDOR CON FONDO REDONDEADO -->
  <div class="w-full max-w-[1300px] bg-[#1A2F1D] rounded-[40px] overflow-hidden border border-[#254229]">

    <!-- HEADER -->
    <div class="px-6 md:px-12 py-12 border-b border-[rgba(255,255,255,0.08)] flex justify-center">
      <div class="max-w-[620px] flex flex-col items-center gap-4 text-center">

        <h2 class="text-white text-3xl md:text-4xl font-semibold leading-tight tracking-tight">
          Todo lo que necesitás para administrar tu gimnasio
        </h2>

        <p class="text-[#B2AEA9] text-sm md:text-base leading-relaxed">
          Funciones pensadas para que gestionar tu gimnasio sea más simple con Gymple.
        </p>

      </div>
    </div>

    <!-- GRID -->
    <div class="px-6 md:px-10 py-12 flex justify-center">
      <div class="w-full grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">

        {features.map((feature) => (
          <article class="p-5 bg-[#1E3522] border border-[#254229] rounded-2xl flex flex-col gap-3 transition-all duration-200 hover:border-[#3B6B41] hover:bg-[#213B26] hover:-translate-y-1">

            <div class="w-10 h-10 bg-white/10 rounded-xl flex items-center justify-center text-white">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d={feature.iconPath} />
              </svg>
            </div>

            <div class="flex flex-col gap-1">
              <h3 class="text-white text-sm font-semibold leading-snug">
                {feature.title}
              </h3>

              <p class="text-[#A9B3AC] text-[13px] leading-relaxed">
                {feature.description}
              </p>
            </div>

          </article>
        ))}

      </div>
    </div>

  </div>

</section>