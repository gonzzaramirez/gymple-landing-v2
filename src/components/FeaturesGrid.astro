---
const features = [
  {
    title: "Gestión y control de socios en tiempo real",
    description: "Fichas completas con foto, datos personales, historial de pagos y estados de cuota actualizados al instante.",
    iconPath: "M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2 M9 7a4 4 0 1 0 0-8 4 4 0 0 0 0 8z M22 21v-2a4 4 0 0 0-3-3.87 M16 3.13a4 4 0 0 1 0 7.75",
  },
  {
    title: "Control de membresías y vencimientos automáticos",
    description: "Definí planes mensuales, trimestrales o anuales. El sistema alerta vencimientos y bloquea accesos automáticamente.",
    iconPath: "M2 10h20 M22 6v12a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2z",
  },
  {
    title: "Registro de asistencia y control de accesos",
    description: "Integrá torniquetes o registrá entradas manualmente. Solo ingresan socios con la cuota al día.",
    iconPath: "M13 4h3a2 2 0 0 1 2 2v14 M2 20h10 M10 20v-6a2 2 0 0 1 2-2h6 M2 14h2 M2 10h2 M2 6h2 M18 20a2 2 0 1 0 0-4 2 2 0 0 0 0 4z",
  },
  {
    title: "Recordatorios automáticos por WhatsApp",
    description: "Recordatorios de vencimiento enviados 3 días antes y el mismo día. Tecnología anti-ban con envíos humanizados.",
    iconPath: "M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z",
  },
  {
    title: "Control de gastos e ingresos de tu gimnasio",
    description: "Registrá cobros y egresos diarios. Visualizá el balance mensual y por método de pago en un solo lugar.",
    iconPath: "M12 2v20 M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6",
  },
  {
    title: "Estadísticas y reportes con filtrado por tiempo",
    description: "Dashboards con métricas clave: socios activos, tasa de cobranza, ingresos. Filtrá por día, semana, mes o rango personalizado.",
    iconPath: "M3 3v18h18 M18 17V9 M13 17V5 M8 17v-3",
  },
  {
    title: "Gestión de rutinas y ejercicios digitales",
    description: "Los entrenadores crean rutinas personalizadas y los socios las ven desde su celular. Sin papeles ni pizarras.",
    iconPath: "M6.5 6.5h11 M6.5 17.5h11 M2 12h2 M20 12h2 M7 12h10 M4 7v10 M20 7v10",
  },
  {
    title: "Soporte dedicado y tecnología en la nube",
    description: "Accedé desde cualquier dispositivo, 24/7. Entorno aislado por gimnasio, backups automáticos y soporte por WhatsApp.",
    iconPath: "M17.5 19H9a7 7 0 1 1 6.71-9h1.79a4.5 4.5 0 1 1 0 9Z",
  },
];
---

<section
  id="funciones"
  class="w-full border-b border-[rgba(55,50,47,0.12)] flex flex-col justify-center items-center bg-[#37322F]"
  aria-labelledby="features-heading"
>
  <div class="self-stretch px-4 sm:px-6 md:px-12 py-8 sm:py-10 md:py-12 border-b border-[rgba(255,255,255,0.12)] flex justify-center items-center gap-6">
    <div class="w-full max-w-[600px] px-4 flex flex-col justify-start items-center gap-3 sm:gap-4">
     
      <h2
        id="features-heading"
        class="w-full text-center flex justify-center flex-col text-white text-3xl md:text-4xl font-semibold leading-[1.1] md:leading-tight font-sans tracking-tight"
      >
        Todo lo que necesitás para administrar tu gimnasio
      </h2>
      <p class="self-stretch text-center text-[#B2AEA9] text-sm md:text-base font-normal leading-relaxed md:leading-7 font-sans">
        Funciones pensadas para que gestionar tu gimnasio sea mas simple con Gymple.
      </p>
    </div>
  </div>

  <div class="self-stretch px-4 sm:px-6 md:px-8 py-8 sm:py-10 md:py-12 flex justify-center">
    <div class="w-full max-w-[1200px] grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3 sm:gap-4 md:gap-5">
      {features.map((feature) => (
        <article class="p-5 md:p-6 bg-[#37322F] border border-[#4A4543] rounded-[20px] md:rounded-3xl flex flex-col gap-3 md:gap-4">
          <div class="w-10 h-10 md:w-12 md:h-12 bg-white/10 rounded-xl md:rounded-2xl flex items-center justify-center text-white">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" class="md:w-6 md:h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d={feature.iconPath} /></svg>
          </div>
          <div>
            <h3 class="text-white text-sm md:text-base font-semibold mb-1.5 md:mb-2 leading-tight">{feature.title}</h3>
            <p class="text-[#B2AEA9] text-[13px] md:text-sm leading-relaxed">{feature.description}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
