---
---

<section
  class="w-full max-w-[960px] lg:w-[960px] pt-2 sm:pt-4 pb-6 sm:pb-8 md:pb-10 px-2 sm:px-4 md:px-6 lg:px-11 flex flex-col justify-center items-center gap-2 relative z-5 my-8 sm:my-12 md:my-16 lg:my-16 mb-0 lg:pb-0"
  aria-label="Vista previa del panel de control de Gymple"
>
  <div class="w-full max-w-[960px] lg:w-[960px] h-[200px] sm:h-[280px] md:h-[450px] lg:h-[600px] bg-white shadow-[0px_0px_0px_0.9056603908538818px_rgba(0,0,0,0.08)] overflow-hidden rounded-[6px] sm:rounded-[8px] lg:rounded-[9.06px] flex flex-col justify-start items-start">
    <div class="self-stretch flex-1 flex justify-start items-start">
      <div class="w-full h-full flex items-center justify-center">
        <div class="w-full h-full bg-[#F7F5F3] flex">
          <!-- Sidebar -->
          <div class="w-12 md:w-48 bg-[#1A2F1D] flex flex-col p-2 md:p-4">
            <div class="flex items-center gap-2 mb-6 md:mb-8">
              <div class="w-6 h-6 md:w-8 md:h-8 bg-white/20 rounded-lg"></div>
              <div class="hidden md:block w-16 h-4 bg-white/20 rounded"></div>
            </div>
            <nav class="space-y-2" aria-label="Menú del panel simulado">
              {[0,1,2,3,4,5,6].map((i) => (
                <div class={`flex items-center gap-2 px-2 py-2 rounded-lg ${i === 1 ? "bg-white/10" : ""}`}>
                  <div class="w-4 h-4 bg-white/40 rounded"></div>
                  <div class="hidden md:block w-16 h-3 bg-white/10 rounded"></div>
                </div>
              ))}
            </nav>
          </div>
          <!-- Main -->
          <div class="flex-1 flex flex-col overflow-hidden">
            <div class="h-10 md:h-14 bg-white border-b border-[#E0DEDB] flex items-center justify-between px-3 md:px-6">
              <div class="flex items-center gap-3">
                <div class="w-24 md:w-32 h-4 bg-[#1A2F1D]/10 rounded"></div>
                <div class="hidden md:block w-32 h-8 bg-[#F7F5F3] rounded-lg"></div>
              </div>
              <div class="w-20 md:w-24 h-7 bg-[#1A2F1D] rounded-lg"></div>
            </div>
            <div class="p-3 md:p-6 grid grid-cols-2 md:grid-cols-4 gap-2 md:gap-4">
              {[1,2,3,4].map(() => (
                <div class="bg-white p-3 md:p-4 rounded-lg border border-[#E0DEDB]">
                  <div class="w-16 h-3 bg-[#E0DEDB] rounded mb-2"></div>
                  <div class="w-12 h-6 bg-[#1A2F1D]/20 rounded mb-1"></div>
                  <div class="w-14 h-2 bg-[#E0DEDB] rounded"></div>
                </div>
              ))}
            </div>
            <div class="flex-1 px-3 md:px-6 pb-3 md:pb-4 overflow-hidden">
              <div class="bg-white rounded-lg border border-[#E0DEDB] h-full overflow-hidden">
                <div class="flex gap-2 md:gap-4 px-3 md:px-4 py-3 bg-[#F7F5F3] border-b border-[#E0DEDB]">
                  <div class="flex-1 h-3 bg-[#E0DEDB] rounded"></div>
                  <div class="w-16 h-3 bg-[#E0DEDB] rounded hidden md:block"></div>
                  <div class="w-12 h-3 bg-[#E0DEDB] rounded"></div>
                  <div class="w-14 h-3 bg-[#E0DEDB] rounded"></div>
                  <div class="w-12 h-3 bg-[#E0DEDB] rounded"></div>
                </div>
                <div class="overflow-auto">
                  {[1,2,3,4,5,6].map((i) => (
                    <div class="flex gap-2 md:gap-4 px-3 md:px-4 py-3 border-b border-[#E0DEDB] last:border-b-0 items-center">
                      <div class="flex-1 flex items-center gap-2">
                        <div class="w-6 h-6 md:w-8 md:h-8 bg-[#1A2F1D]/10 rounded-full"></div>
                        <div class="w-20 md:w-28 h-3 bg-[#E0DEDB] rounded"></div>
                      </div>
                      <div class="w-16 h-3 bg-[#E0DEDB] rounded hidden md:block"></div>
                      <div class="w-12 h-3 bg-[#E0DEDB] rounded"></div>
                      <div class={`w-14 h-5 rounded-full ${i % 3 === 0 ? "bg-red-100" : i % 3 === 1 ? "bg-amber-100" : "bg-green-100"}`}></div>
                      <div class="w-12 h-3 bg-[#E0DEDB] rounded"></div>
                    </div>
                  ))}
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
